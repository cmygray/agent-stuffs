#!/bin/bash
set -euo pipefail

# Usage: orch-worker <unit-file>
# Worker 에이전트를 실행하여 Unit spec을 구현합니다.
# worktree에서 격리 실행되며, 결과는 structured JSON으로 반환됩니다.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "${SCRIPT_DIR}/../lib/common.sh"
source "${SCRIPT_DIR}/../lib/deps.sh"
source "${SCRIPT_DIR}/../lib/state.sh"

UNIT_FILE="$1"
UNIT_ID=$(unit_id "$UNIT_FILE")
UNIT_NUM=$(unit_num "$UNIT_ID")
SCHEMA="${ORCH_ROOT}/schemas/worker-output.json"

ensure_state_dir

# 0. 선행 Unit 의존성 체크
check_deps "$UNIT_FILE"

echo "=== Worker: ${UNIT_ID} ==="

# 1. plan.md 상태를 [~] 진행중으로 변경
update_plan_status "$UNIT_NUM" "[ ]" "[~]"

# 2. 선행 Unit의 decisions를 수집하여 컨텍스트로 전달
PRIOR_DECISIONS=$(collect_prior_decisions)

# 3. Worker 실행 전 worktree 목록 스냅샷
WORKTREES_BEFORE=$(snapshot_worktrees)

# 4. Worker 실행
RESULT=$(claude -p "$(cat "$UNIT_FILE")${PRIOR_DECISIONS}" \
  --json-schema "$(cat "$SCHEMA")" \
  --output-format json \
  --model opus \
  --worktree \
  --dangerously-skip-permissions \
  --append-system-prompt "You are a worker agent. Implement exactly what the spec says. Do not ask questions. Read all Context Files before starting.")

# 5. structured_output 추출
RESULT_JSON=$(extract_structured_output "$RESULT" \
  '{"status":"failed","files_created":[],"files_modified":[],"decisions":[],"issues":["No structured_output in response"]}')

STATUS=$(echo "$RESULT_JSON" | jq -r '.status')

# 6. 새로 생성된 worktree 경로 탐지
WORKTREE_PATH=$(detect_new_worktree "$WORKTREES_BEFORE")

if [ -n "$WORKTREE_PATH" ]; then
  WORKTREE_PATH=$(cd "$WORKTREE_PATH" && pwd)
  save_worktree_path "$UNIT_ID" "$WORKTREE_PATH"
  echo "Worktree: ${WORKTREE_PATH}"
else
  echo "WARNING: No new worktree detected"
fi

# 7. decisions를 축적 로그에 기록
record_decisions "$UNIT_ID" "$RESULT_JSON"

# 8. plan.md 상태 업데이트
if [ "$STATUS" = "done" ]; then
  update_plan_status "$UNIT_NUM" "[~]" "[x]"
  MARKER="[x]"
else
  update_plan_status "$UNIT_NUM" "[~]" "[!]"
  MARKER="[!]"
fi

# 9. unit 파일에 결과 기록
append_result_section "$UNIT_FILE" "Worker Output" "$RESULT_JSON"

# 10. 요약 출력
echo "=== ${UNIT_ID}: ${MARKER} (status: ${STATUS}) ==="
echo "$RESULT_JSON" | jq '.'

# 11. session ID 출력
SESSION_ID=$(extract_session_id "$RESULT")
echo "Session: ${SESSION_ID}"
